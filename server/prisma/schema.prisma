generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PROFESSOR
  TA
  ADMIN
}

enum InstructorRole {
  LEAD
  ASSISTANT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructorOf           CourseInstructor[]
  enrolledIn             CourseEnrollment[]
  submissions            Submission[]
  sessions               Session[]
  accounts               Account[]
  emailVerified          Boolean                 @default(false)
  image                  String?
  aiChatSessions         AiChatSession[]
  activityFeedback       ActivityFeedback[]
  activityStudentMetrics ActivityStudentMetric[]
  aiInteractionTraces    AiInteractionTrace[]

  @@map("User")
}

model PromptTemplate {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  systemPrompt String
  temperature  Float?
  topP         Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities Activity[]
}

model CourseOffering {
  id               Int       @id @default(autoincrement())
  title            String
  description      String?
  startDate        DateTime?
  endDate          DateTime?
  isPublished      Boolean   @default(false)
  externalId       String?
  externalSource   String?
  externalMetadata Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  modules     Module[]
  instructors CourseInstructor[]
  enrollments CourseEnrollment[]
  topics      Topic[]

  @@index([externalId])
}

model Topic {
  id               Int            @id @default(autoincrement())
  name             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  courseOfferingId Int

  mainActivities      Activity[]               @relation("ActivityMainTopic")
  secondaryActivities ActivitySecondaryTopic[]

  @@unique([courseOfferingId, name])
}

model CourseInstructor {
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  courseOfferingId Int
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  role             InstructorRole @default(LEAD)
  assignedAt       DateTime       @default(now())

  @@id([courseOfferingId, userId])
}

model CourseEnrollment {
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  courseOfferingId Int
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  enrolledAt       DateTime       @default(now())

  @@id([courseOfferingId, userId])
}

model Module {
  id               Int            @id @default(autoincrement())
  title            String
  description      String?
  position         Int            @default(0)
  isPublished      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courseOffering   CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  courseOfferingId Int

  lessons Lesson[]
}

model Lesson {
  id          Int      @id @default(autoincrement())
  title       String
  contentMd   String?
  position    Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId    Int

  activities Activity[]
}

model Activity {
  id                Int             @id @default(autoincrement())
  title             String?
  instructionsMd    String
  config            Json?
  position          Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lesson            Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId          Int
  promptTemplate    PromptTemplate? @relation(fields: [promptTemplateId], references: [id])
  promptTemplateId  Int?
  customPrompt      String?
  customPromptTitle String?

  mainTopic       Topic                    @relation("ActivityMainTopic", fields: [mainTopicId], references: [id])
  mainTopicId     Int
  secondaryTopics ActivitySecondaryTopic[]

  enableTeachMode  Boolean @default(true)
  enableGuideMode  Boolean @default(true)
  enableCustomMode Boolean @default(false)

  submissions            Submission[]
  aiChatSessions         AiChatSession[]
  activityFeedback       ActivityFeedback[]
  activityAnalytics      ActivityAnalytics?
  activityStudentMetrics ActivityStudentMetric[]
  aiInteractionTraces    AiInteractionTrace[]
}

model Submission {
  id               Int                @id @default(autoincrement())
  attemptNumber    Int                @default(1)
  response         Json?
  aiFeedback       Json?
  score            Float?
  isCorrect        Boolean?
  createdAt        DateTime           @default(now())
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  activity         Activity           @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId       Int
  activityFeedback ActivityFeedback[]
}

model ActivitySecondaryTopic {
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId Int
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId    Int

  @@id([activityId, topicId])
}

model SystemPrompt {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityFeedback {
  id           Int         @id @default(autoincrement())
  rating       Int
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  activity     Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId   Int
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  submissionId Int?

  @@unique([userId, activityId])
}

model ActivityStudentMetric {
  id                       Int      @id @default(autoincrement())
  helpRequestCount         Int      @default(0)
  submissionCount          Int      @default(0)
  incorrectSubmissionCount Int      @default(0)
  correctSubmissionCount   Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                   Int
  activity                 Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId               Int

  @@unique([userId, activityId])
}

model ActivityAnalytics {
  id                       Int      @id @default(autoincrement())
  helpRequestCount         Int      @default(0)
  submissionCount          Int      @default(0)
  incorrectSubmissionCount Int      @default(0)
  correctSubmissionCount   Int      @default(0)
  studentCount             Int      @default(0)
  feedbackCount            Int      @default(0)
  averageRating            Float?
  difficultyScore          Int      @default(0)
  difficultyLabel          String   @default("LOW")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  activity                 Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId               Int      @unique
}

model SuggestedPrompt {
  id        Int      @id @default(autoincrement())
  mode      String // 'teach' or 'guide'
  text      String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiChatSession {
  id                  Int                  @id @default(autoincrement())
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              Int
  activity            Activity             @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId          Int
  mode                String
  chatId              String
  modelId             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  aiInteractionTraces AiInteractionTrace[]

  @@unique([userId, activityId, mode])
}

model AiInteractionTrace {
  id                Int            @id @default(autoincrement())
  mode              String
  knowledgeLevel    String?
  chatId            String?
  tutorModelId      String?
  supervisorModelId String?
  userMessage       String
  finalResponse     String
  finalOutcome      String
  iterationCount    Int            @default(0)
  trace             Json
  createdAt         DateTime       @default(now())
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  activity          Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId        Int
  aiChatSession     AiChatSession? @relation(fields: [aiChatSessionId], references: [id], onDelete: SetNull)
  aiChatSessionId   Int?
}

// Better Auth tables (minimal)

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  @@map("Session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                Int
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("Account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("Verification")
}
