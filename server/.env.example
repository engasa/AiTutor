# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:54321/aitutor?schema=public"

# Server Configuration
PORT=4000

# Authentication
BETTER_AUTH_SECRET="replace-with-a-random-strong-secret"
BETTER_AUTH_URL="http://localhost:4000/api/auth"
COOKIE_DOMAIN="localhost"

# UBC eduAI API Configuration
EDUAI_API_KEY="your-eduai-api-key-here"
EDUAI_BASE_URL="http://localhost:5174/api"
EDUAI_MODEL="google:gemini-2.5-flash"

# AI Supervisor (two-agent review)
# Set to "false" to disable supervisor review loop
AI_SUPERVISOR_ENABLED=true
