{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "ignorePatterns": [
    "node_modules",
    "build",
    "dist",
    ".react-router",
    "server/node_modules",
    "server/prisma/migrations"
  ]
}
